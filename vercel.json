{
    "buildCommand": "npm run build",
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "rewrites": [
        { "source": "/build/(.*)", "destination": "/public/build/$1" },
        { "source": "/(.*)", "destination": "/api/index.php" }
    ],
    "headers": [
        {
            "source": "/build/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        }
    ],
    "cleanUrls": true
}
