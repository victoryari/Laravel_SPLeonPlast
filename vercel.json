{
    "builds": [
        { "src": "api/index.php", "use": "vercel-php@0.9.0" },
        { "src": "public/**", "use": "@vercel/static" }
    ],
    "routes": [
        { "src": "/build/(.*)", "dest": "public/build/$1" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "headers": [
        {
            "source": "/build/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        }
    ],
    "env": {
        "APP_NAME": "LeonPlast",
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "https://leonplast-laravel.vercel.app",
        "APP_KEY": "base64:N6tEixmpkzXCrHpCMfLpcG/7ojyqydunKt6OT8hDLYQ=",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "CACHE_DRIVER": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "VIEW_COMPILED_PATH": "/tmp/views",
        "SSR_TEMP_PATH": "/tmp/ssr",
        "DB_CONNECTION": "mysql",
        "DB_HOST": "gateway01.us-west-2.prod.aws.tidbcloud.com",
        "DB_PORT": "4000",
        "DB_DATABASE": "leonplast_produccion",
        "DB_USERNAME": "FFaQUCztTh8ZAi6.root",
        "MYSQL_ATTR_SSL_CA": "storage/app/certs/global-bundle.pem",
        "MYSQL_ATTR_SSL_VERIFY_SERVER_CERT": "false"
    }
}
